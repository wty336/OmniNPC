# ============================
# OmniNPC 环境配置
# 复制此文件为 .env 并填入你的 API Key
# ============================

# 火山方舟 API Key（必填）
# 获取方式: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=your_ark_api_key_here

# 火山方舟模型 Endpoint ID（必填）
# 在火山方舟控制台创建推理接入点后获取
ARK_MODEL_ENDPOINT=your_endpoint_id_here

# 可选: 备用 OpenAI API Key
# OPENAI_API_KEY=sk-xxx

# 应用级配置建议使用 OMNI_NPC_ 前缀，避免与系统环境变量冲突
# 是否开启调试模式: true / false
OMNI_NPC_DEBUG=false

# 日志级别: DEBUG / INFO / WARNING / ERROR
OMNI_NPC_LOG_LEVEL=INFO
